# Trigger.dev
TRIGGER_SECRET_KEY=

# ClickHouse Cloud
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
# Read-only analytics user (SELECT on postings only); created against the service, see task 003.
CLICKHOUSE_RO_USER=
CLICKHOUSE_RO_PASSWORD=

# ClickHouse Managed Postgres
DATABASE_URL=

# Better Auth (task 012). Server-only secrets - NEVER commit real values. BETTER_AUTH_SECRET is a
# random 32-byte value (openssl rand -base64 32); BETTER_AUTH_URL is the app origin (e.g.
# http://localhost:3000 locally, https://jobchat.dev in prod). Google OAuth client is operator
# console work - absent GOOGLE_* the app runs email/password only (Google is registered on env
# presence). Auth never runs in Trigger; mirror these in Vercel only.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS Bedrock (Claude models). Alternative: comment the keys and use a local profile.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=

# searchnapply.com REST API (external data source). Auth and jobs are separate
# services (locally :5001 vs :5003); SEARCHNAPPLY_API_URL is the jobs base only.
SEARCHNAPPLY_API_URL=
SEARCHNAPPLY_AUTH_URL=
SEARCHNAPPLY_EMAIL=
SEARCHNAPPLY_PASSWORD=

# Session guards + agent loop ceilings (task 004). All optional - unset falls back to these
# conservative defaults; tune once prod traffic is understood.
GUEST_MESSAGE_CAP=10
DAILY_MESSAGE_BUDGET=200
AGENT_MAX_TURNS=10
AGENT_MAX_STEPS=8
